{
  "name": "ccx-kit",
  "type": "module",
  "version": "1.0.2",
  "packageManager": "pnpm@11.1.1",
  "description": "CCX-Kit - One-click setup and management tool for CCX AI API proxy",
  "author": {
    "name": "BenedictKing",
    "url": "https://github.com/BenedictKing"
  },
  "license": "MIT",
  "homepage": "https://github.com/BenedictKing/ccx-kit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BenedictKing/ccx-kit.git"
  },
  "bugs": "https://github.com/BenedictKing/ccx-kit/issues",
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "config",
    "cli",
    "setup",
    "ccx",
    "ccx-kit",
    "cck",
    "anthropic",
    "openai",
    "ChatGPT",
    "ai",
    "automation",
    "mcp"
  ],
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "bin": {
    "ccx-kit": "bin/ccx-kit.mjs",
    "cck": "bin/cck.mjs"
  },
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "scripts": {
    "dev": "tsx ./src/cli.ts",
    "build": "unbuild",
    "start": "node bin/ccx-kit.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "update:deps": "pnpx taze major -r -w",
    "release": "pnpm build && pnpm publish --access public",
    "docs:dev": "pnpm -F @ccx-kit/docs dev",
    "docs:build": "pnpm -F @ccx-kit/docs build",
    "docs:preview": "pnpm -F @ccx-kit/docs preview"
  },
  "dependencies": {
    "@rainbowatcher/toml-edit-js": "catalog:runtime",
    "@types/semver": "catalog:types",
    "ansis": "catalog:cli",
    "cac": "catalog:cli",
    "dayjs": "catalog:runtime",
    "find-up-simple": "catalog:runtime",
    "fs-extra": "catalog:runtime",
    "i18next": "catalog:runtime",
    "i18next-fs-backend": "catalog:runtime",
    "inquirer": "catalog:cli",
    "inquirer-toggle": "catalog:cli",
    "ora": "catalog:cli",
    "pathe": "catalog:runtime",
    "semver": "catalog:runtime",
    "tinyexec": "catalog:runtime",
    "trash": "catalog:runtime"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:build",
    "@types/fs-extra": "catalog:types",
    "@types/inquirer": "catalog:types",
    "@types/node": "catalog:types",
    "@vitest/coverage-v8": "catalog:testing",
    "@vitest/ui": "catalog:testing",
    "eslint": "catalog:build",
    "eslint-plugin-format": "catalog:build",
    "glob": "catalog:testing",
    "tsx": "catalog:build",
    "typescript": "catalog:build",
    "unbuild": "catalog:build",
    "vitest": "catalog:testing"
  }
}
